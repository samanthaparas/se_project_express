{
  "env": {
    "es2021": true,
    "node": true
  },
  "extends": ["eslint:recommended", "airbnb-base", "prettier"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "rules": {
    "no-console": ["warn", { "allow": ["error"] }],
    "no-unused-vars": ["error", { "argsIgnorePattern": "next" }],
    "camelcase": ["error", { "allow": ["_id"] }],
    "no-underscore-dangle": ["error", { "allow": ["_id"] }]
  }
}
